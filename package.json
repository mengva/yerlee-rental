{
  "name": "yerlee-rental",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "start:server": "cd apps/server && bun --hot src/server/index.ts",
    "db:push": "cd apps/server && bunx drizzle-kit push",
    "db:generate": "cd apps/server && bunx drizzle-kit generate",
    "db:migrate": "cd apps/server && bunx drizzle-kit migrate",
    "db:studio": "cd apps/server && bunx drizzle-kit studio",
    "dev:landing": "cd apps/web-landing && bun run dev",
    "build:landing": "cd apps/web-landing && bun run build",
    "dev:admin": "cd apps/web-admin && bun run dev",
    "build:admin": "cd apps/web-admin && bun run build"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.1",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.2",
    "@tanstack/react-query": "^5.96.1",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.10.0",
    "@types/jsdom": "^28.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "create": "",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "latest",
    "jsdom": "^28.1.0",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.19.0",
    "rate-limiter-flexible": "^9.1.1",
    "react-hot-toast": "^2.6.0",
    "redis": "^5.11.0",
    "resend": "^6.9.4",
    "server": "",
    "superjson": "^2.2.6",
    "zod": "^3.25.76"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}